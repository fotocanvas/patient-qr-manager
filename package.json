{
  "name": "patient-qr-manager",
  "version": "1.3.1",
  "description": "病人影像二维码归档管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "dependencies": {
    "@zxing/library": "^0.21.3",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.doctor.patient-qr-manager",
    "productName": "病人影像归档",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "病人影像归档"
    }
  },
  "allowScripts": {
    "electron@28.3.3": true
  }
}
